# AI HTML IR Agent
# The server reads packages/server/.env first, then process env vars.
# The endpoint must be compatible with OpenAI Chat Completions:
#   POST /v1/chat/completions
AI_AGENT_BASE_URL=https://api.openai.com/v1
AI_AGENT_API_KEY=sk-xx
AI_AGENT_MODEL=gpt-4o
AI_AGENT_MAX_TOKENS=12000

# Optional generic OpenAI-compatible fallbacks.
# AI_AGENT_* takes precedence when both are set.
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xx
# OPENAI_MODEL=gpt-4o
